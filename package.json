{
  "name": "video-editor-tauri",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "start": "tauri dev",
    "build:dmg": "tauri build --config src-tauri/tauri.macos.conf.json --target aarch64-apple-darwin --bundles dmg",
    "build:mas:app": "tauri build --config src-tauri/tauri.appstore.conf.json --target aarch64-apple-darwin --bundles app",
    "build:mas:pkg": "npm run build:mas:app && node scripts/package-mas-pkg.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "axios": "^1.16.1",
    "vue": "^3.5.13",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@vitejs/plugin-vue": "^5.2.1",
    "vite": "^6.0.3"
  }
}
