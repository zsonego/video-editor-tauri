{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "艾咔",
  "version": "0.1.1",
  "identifier": "com.loogear.aicut",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "艾咔",
        "width": 1280,
        "height": 850,
        "minWidth": 1100,
        "minHeight": 720,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**",
          "$LOCALDATA/aicut/template/**",
          "$APPDATA/aicut/template/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/logo.png",
      "icons/logo.png",
      "icons/logo.png",
      "icons/AICut.icns",
      "icons/AICut.ico"
    ]
  }
}
